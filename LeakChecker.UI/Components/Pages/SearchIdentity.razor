@page "/search"
@rendermode InteractiveServer
@using LeakChecker.Common.Enums
@inherits SearchIdentityBase

<PageTitle>Search Identity</PageTitle>

<style>
    .search-title {
        font-size: 20px;
        font-weight: 500;
        color: #212529;
        margin-bottom: 1.5rem;
    }

    .search-card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 10px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .search-row {
        display: flex;
        gap: 10px;
        align-items: stretch;
    }

    .search-input {
        flex: 1;
        height: 38px;
        padding: 0 12px;
        font-size: 13px;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        color: #212529;
        background: #fff;
        outline: none;
        transition: border-color 0.15s;
    }

    .search-input:focus {
        border-color: #868e96;
    }

    .search-select {
        height: 38px;
        padding: 0 10px;
        font-size: 13px;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        color: #212529;
        background: #fff;
        cursor: pointer;
        outline: none;
        transition: border-color 0.15s;
        min-width: 130px;
    }

    .search-select:focus {
        border-color: #868e96;
    }

    .search-btn {
        height: 38px;
        padding: 0 20px;
        font-size: 13px;
        font-weight: 500;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: opacity 0.15s;
        display: flex;
        align-items: center;
        gap: 6px;
        background: #3d35a8;
        color: #fff;
    }

    .search-btn:hover {
        opacity: 0.88;
    }

    .search-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .section-title {
        font-size: 13px;
        font-weight: 500;
        color: #868e96;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 1rem;
    }

    .results-table {
        width: 100%;
        font-size: 12px;
        border-collapse: collapse;
        font-family: monospace;
    }

    .results-table th {
        text-align: left;
        font-weight: 500;
        color: #868e96;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .04em;
        padding: 0 12px 8px 0;
        border-bottom: 1px solid #dee2e6;
        font-family: sans-serif;
    }

    .results-table td {
        padding: 8px 12px 8px 0;
        color: #212529;
        border-bottom: 1px solid #f1f3f5;
        word-break: break-all;
        max-width: 300px;
    }

    .results-table tr:last-child td {
        border-bottom: none;
    }

    .results-table tr:hover td {
        background: #f8f9fa;
    }

    .results-table td.col-source {
        max-width: 200px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .source-badge {
        display: inline-block;
        font-family: sans-serif;
        font-size: 11px;
        font-weight: 500;
        color: #5f3dc4;
        background: #f3f0ff;
        border: 1px solid #d0bfff;
        border-radius: 4px;
        padding: 1px 7px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 190px;
        vertical-align: middle;
        cursor: default;
    }

    .empty-state {
        color: #adb5bd;
        font-size: 13px;
        text-align: center;
        padding: 2.5rem 0;
    }

    .result-count {
        font-size: 12px;
        color: #868e96;
        margin-bottom: 10px;
    }

    .error-msg {
        color: #c92a2a;
        font-size: 13px;
        margin-top: 10px;
    }
</style>

<div class="search-title">Search Identity</div>

<div class="search-card">
    <div class="search-row">
        <input class="search-input"
               type="text"
               placeholder="Enter search value…"
               @bind="SearchValue"
               @bind:event="oninput"
               @onkeydown="OnKeyDown" />

        <select class="search-select" @bind="SelectedCondition">
            @foreach (var c in Enum.GetValues<ConditionType>())
            {
            <option value="@c">@c</option>
            }
        </select>

        <select class="search-select" @bind="SelectedItem">
            @foreach (var item in SearchableItems)
            {
            <option value="@item">@item</option>
            }
        </select>

        <button class="search-btn" @onclick="RunSearch" disabled="@(IsSearching || string.IsNullOrWhiteSpace(SearchValue))">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
            </svg>
            @if (IsSearching)
            {
            <span>Searching…</span>
            }
            else
            {
            <span>Search</span>
            }
        </button>
    </div>

    @if (ErrorMessage is not null)
    {
    <div class="error-msg">@ErrorMessage</div>
    }
</div>

@if (IsSearching)
{
<div class="search-card">
    <div style="display:flex;align-items:baseline;gap:12px;">
        <div class="section-title" style="margin-bottom:0;">Searching…</div>
        <div style="font-size:15px;color:#868e96;font-family:monospace;">
            @Elapsed.ToString(@"hh\:mm\:ss")
        </div>
    </div>
</div>
}

@if (HasSearched)
{
<div class="search-card">
    <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:1rem;">
        <div class="section-title" style="margin-bottom:0;">Results in</div>
        <div style="font-size:15px;color:#868e96;font-family:monospace;">
            @Elapsed.ToString(@"hh\:mm\:ss")
        </div>
    </div>

    @if (Results.Count == 0)
    {
    <div class="empty-state">No records found.</div>
    }
    else
    {
    <div class="result-count">
        Showing <strong>@TotalLoaded</strong> of <strong>@(TotalMatched?.ToString("N0") ?? "…")</strong> records found
    </div>
    <div style="overflow-x:auto;">
        <table class="results-table">
            <thead>
            <tr>
                @foreach (var col in ResultColumns)
                {
                <th>@col</th>
                }
            </tr>
            </thead>
            <tbody>
            @foreach (var row in Results)
            {
            <tr>
                @foreach (var col in ResultColumns)
                {
                @if (col == "Source")
                {
                    <td class="col-source">
                        @{
                            var sourceName = row.GetValueOrDefault("Source", "-");
                            var sourcePath = row.GetValueOrDefault("Source_path", null);
                            var navId      = row.GetValueOrDefault("Source_navid", null);
                        }
                        <span class="source-badge"
                              title="@(sourcePath ?? sourceName)"
                              @onclick="@(() => { if (navId is not null) Nav.NavigateTo($"/parse/{navId}"); })">
                            @sourceName
                        </span>
                    </td>
                }
                else
                {
                    <td title="@col">@row.GetValueOrDefault(col, "-")</td>
                }
                }
            </tr>
            }
            </tbody>
        </table>
        @if (HasMore)
        {
        <div style="margin-top:1rem;text-align:center;">
            <button class="search-btn" style="margin:0 auto;" @onclick="LoadMore" disabled="@IsLoadingMore">
                @if (IsLoadingMore)
                {
                <span>Loading…</span>
                }
                else
                {
                <span>Load more</span>
                }
            </button>
        </div>
        }
    </div>
    }
</div>
}