@page "/"
@using LeakChecker.UI.Helpers
@inherits HomeBase
@rendermode InteractiveServer

<PageTitle>Dashboard</PageTitle>

<style>
    .dash-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 12px;
        margin-bottom: 2rem;
    }
    .metric-card {
        padding: 1rem 1.25rem;
        border: 1px solid #dee2e6;
        border-radius: 10px;
        background: #fff;
    }
    .metric-label { font-size: 12px; color: #868e96; margin-bottom: 6px; }
    .metric-value { font-size: 24px; font-weight: 500; color: #212529; }
    .metric-sub   { font-size: 12px; color: #adb5bd; margin-top: 4px; }
    .section-title { font-size: 15px; font-weight: 500; color: #212529; margin-bottom: 12px; }
    .parse-table { width: 100%; font-size: 13px; border-collapse: collapse; }
    .parse-table th {
        text-align: left;
        font-weight: 500;
        color: #868e96;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0 12px 8px 0;
        border-bottom: 1px solid #dee2e6;
    }
    .parse-table td {
        padding: 10px 12px 10px 0;
        color: #212529;
        border-bottom: 1px solid #f1f3f5;
        font-family: monospace;
        font-size: 12px;
    }
    .parse-table tr:last-child td { border-bottom: none; }
    .parse-table tbody tr { cursor: pointer; transition: background 0.1s; }
    .parse-table tbody tr:hover td { background: #f8f9fa; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; background: #e9ecef; color: #495057; font-family: sans-serif; }
    .status-ok   { background: #d3f9d8; color: #2b8a3e; }
    .status-warn { background: #fff3bf; color: #e67700; }
    .status-err  { background: #ffe3e3; color: #c92a2a; }
    .refresh-btn { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: #868e96; background: none; border: 1px solid #dee2e6; border-radius: 6px; padding: 4px 12px; cursor: pointer; }
    .refresh-btn:hover { background: #f8f9fa; }
    .error-box { padding: 1rem; border-radius: 8px; background: #fff5f5; border: 1px solid #ffc9c9; color: #c92a2a; font-size: 13px; }
    .source-badge {
        display: inline-block;
        font-family: sans-serif;
        font-size: 11px;
        font-weight: 500;
        color: #5f3dc4;
        background: #f3f0ff;
        border: 1px solid #d0bfff;
        border-radius: 4px;
        padding: 1px 7px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
        vertical-align: middle;
        cursor: pointer;
    }
    .source-badge:hover { background: #ece9ff; }

    .parse-table th:first-child,
    .parse-table td:first-child {
        width: 470px;      /* adjust this one number to taste */
    }
</style>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
    <span style="font-size:18px;font-weight:500;">Dashboard</span>
    <button class="refresh-btn" @onclick="Load">
        <span style="font-size:15px;line-height:1;">&#x21BA;</span>
        Refresh
    </button>
</div>

@if (Error is not null)
{
<div class="error-box">Could not connect to MongoDB: @Error</div>
}
else if (!Loaded)
{
<p style="color:#adb5bd;font-size:13px;">Loading...</p>
}
else
{
<div class="dash-grid">
    <MetricCard Label="Identities"      Value="@StringFormatter.Number(Stats.TotalRecords)" Sub="total records"  />
    <MetricCard Label="Files"           Value="@StringFormatter.Number(Stats.TotalParses)"  Sub="total parsed"    />
    <MetricCard Label="Avg accuracy"    Value="@StringFormatter.Percent(Stats.Accuracy)"    Sub="weighted across all parses" />
    <MetricCard Label="Data size"       Value="@StringFormatter.Bytes(Stats.TotalBytes)"    Sub="all files"  />
</div>

<div class="section-title">Recent parses</div>
<table class="parse-table">
    <thead>
    <tr>
        @foreach (var col in Columns)
        {
            <th>@col.Header</th>
        }
    </tr>
    </thead>
    <tbody>
    @foreach (var p in RecentParses)
    {
        <tr>
            @foreach (var col in Columns)
            {
                @if (col.Header == "File Name")
                {
                    <td>
                        <span class="source-badge"
                              title="@p.SourcePath"
                              @onclick='() => Nav.NavigateTo($"/parse/{p.ParseId}")'>
                            @col.Value(p)
                        </span>
                    </td>
                }
                else if (col.Header == "Accuracy")
                {
                    <td title="@col.Header">
                        <span class="badge @AccuracyClass(p.Accuracy)">@col.Value(p)</span>
                    </td>
                }
                else
                {
                    <td title="@col.Header">@col.Value(p)</td>
                }
            }
        </tr>
    }
    </tbody>
</table>
}