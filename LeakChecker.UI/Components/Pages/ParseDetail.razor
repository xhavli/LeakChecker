@page "/parse/{ParseId}"
@using LeakChecker.UI.Helpers
@inherits ParseDetailBase
@rendermode InteractiveServer

<PageTitle>Parse Detail</PageTitle>

<script>
    window.setSubSchemas = (open) => {
        document.querySelectorAll('#schemas-root details').forEach(d => d.open = open);
    };
</script>

<style>
    .detail-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; margin-bottom: 2rem; }
    .metric-card  { padding: 1rem 1.25rem; border: 1px solid #dee2e6; border-radius: 10px; background: #fff; }
    .metric-label { font-size: 12px; color: #868e96; margin-bottom: 6px; }
    .metric-value { font-size: 24px; font-weight: 500; color: #212529; }
    .metric-sub   { font-size: 12px; color: #adb5bd; margin-top: 4px; }
    .section-title { font-size: 15px; font-weight: 500; color: #212529; margin: 1.5rem 0 10px; }
    .detail-table { width: 100%; font-size: 12px; border-collapse: collapse; font-family: monospace; }
    .detail-table th { text-align: left; font-weight: 500; color: #868e96; font-size: 11px;
        text-transform: uppercase; letter-spacing: .04em; padding: 0 12px 8px 0;
        border-bottom: 1px solid #dee2e6; }
    .detail-table td { padding: 8px 12px 8px 0; color: #212529; border-bottom: 1px solid #f1f3f5; }
    .detail-table tr:last-child td { border-bottom: none; }
    .badge { display:inline-block; padding:2px 8px; border-radius:4px; font-size:11px;
        background:#e9ecef; color:#495057; font-family:sans-serif; }
    .status-ok   { background:#d3f9d8; color:#2b8a3e; }
    .status-warn { background:#fff3bf; color:#e67700; }
    .status-err  { background:#ffe3e3; color:#c92a2a; }
    .back-btn { font-size:12px; color:#868e96; background:none; border:1px solid #dee2e6;
        border-radius:6px; padding:4px 12px; cursor:pointer; margin-bottom:1.5rem; }
    .back-btn:hover { background:#f8f9fa; }
    .code-block { font-size:12px; font-family:monospace; background:#f8f9fa; border:1px solid #e9ecef;
        border-radius:6px; padding:.75rem 1rem; white-space:pre-wrap; word-break:break-all; }
    .pill { display:inline-block; padding:2px 10px; border-radius:20px; font-size:12px;
        background:#e7f5ff; color:#1971c2; margin:0 4px 4px 0; font-family:sans-serif; }
    details > summary { cursor: pointer; list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
    details > summary .arrow { display: inline-block; transition: transform 0.2s; }
    details[open] > summary .arrow { transform: rotate(90deg); }
</style>

<button class="back-btn" @onclick='() => Nav.NavigateTo("/")'>
    <span style="position:relative;top:-1px;">&#8592;</span>
    <span>Back</span>
</button>

@if (Error is not null)
{
    <div style="color:#c92a2a;font-size:13px;">@Error</div>
}
else if (!Loaded)
{
    <p style="color:#adb5bd;font-size:13px;">Loading&#8230;</p>
}
else if (Detail is null)
{
    <p style="color:#adb5bd;font-size:13px;">Parse not found.</p>
}
else
{
    <div style="padding-bottom:8rem;">
    <div style="margin-bottom:1.5rem;">
        <span style="font-size:13px;color:#868e96;">Parsing of</span>
        <div style="font-size:24px;font-weight:500;">@Detail.FileName</div>
    </div>

    <div class="detail-grid" style="grid-template-columns: repeat(4, 1fr);">
        <MetricCard Label="Lines"       Value="@Formatter.Number(Detail.LinesRead)"     Sub="total read" />
        <MetricCard Label="Records"     Value="@Formatter.Number(Detail.RecordsRead)"   Sub="total parsed" />
        <MetricCard Label="Malformed"   Value="@Formatter.Number(Detail.MalformedRead)" Sub="skipped" />
        <MetricCard Label="Accuracy"    Value="@Formatter.Percent(Detail.Accuracy)"     Sub="parse quality" />
        <MetricCard Label="File size"   Value="@Formatter.Bytes(Detail.FileSize)"       Sub="on disk" />
        <MetricCard Label="Speed"       Value="@($"{Formatter.Bytes((long)Detail.ByteSpeed)}/s")"    Sub="physical throughput" />
        <MetricCard Label="Line speed"  Value="@($"{Detail.LineSpeed:F2} ln/s")"        Sub="logical throughput" />
        <MetricCard Label="Duration"    Value="@Formatter.Duration(Detail.Duration)"    />
    </div>

    <div class="section-title">Identifiers</div>
    <table class="detail-table" style="padding-left:1.25rem;">
        <tr><td style="color:#868e96;width:140px;">Execution ID</td>    <td>@Detail.ExecutionId</td></tr>
        <tr><td style="color:#868e96;">Parse ID</td>                    <td>@Detail.ParseId</td></tr>
        <tr><td style="color:#868e96;">Source path</td>                 <td>@Detail.SourcePath</td></tr>
        <tr><td style="color:#868e96;">Started</td>                     <td>@Detail.ParseStart.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td></tr>
        <tr><td style="color:#868e96;">Finished</td>                    <td>@Detail.ParseEnd.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td></tr>
    </table>
    
    <div class="section-title">Context (@Detail.Context.Count)</div>
    @if (Detail.Context.Any())
    {
        <div style="margin-bottom:1rem;padding-left:1.25rem;">
            @foreach (var (ctx, count) in RunLengthEncode(Detail.Context))
            {
                <span class="pill" style="background:#f3f0ff;color:#6741d9;display:inline-flex;align-items:center;gap:5px;">
                    @ctx
                    @if (count > 1) {
                        <span style="background:rgba(0,0,0,0.12);border-radius:20px;font-size:11px;font-weight:500;padding:1px 5px;">× @count</span>
                    }
                </span>
            }
        </div>
    }
    
    @if (Detail.Schemas.Any())
    {
        var distinctTypes = Detail.Schemas
            .SelectMany(s => s.Values)
            .GroupBy(v => v)
            .OrderByDescending(g => g.Count())
            .ToList();

        <div class="section-title">Items Found (@distinctTypes.Count)</div>
        <div style="margin-bottom:1rem;padding-left:1.25rem;">
            @foreach (var g in distinctTypes)
            {
                <span class="pill" style="background:#e3fafc;color:#0c8599;">@g.Key</span>
            }
        </div>
    }

    <div class="section-title">Format (@Detail.Formats.Count)</div>
    <div style="padding-left:1.25rem;">
        @if (Detail.Formats.Any())
        {
            @foreach (var (f, count) in RunLengthEncode(Detail.Formats))
            {
                <span class="pill" style="display:inline-flex;align-items:center;gap:5px;">
                    @f
                    @if (count > 1) {
                        <span style="background:rgba(0,0,0,0.12);border-radius:20px;font-size:11px;font-weight:500;padding:1px 5px;">× @count</span>
                    }
                </span>
            }
        }
        else
        {
            <span style="color:#adb5bd;font-size:12px;">none detected</span>
        }
    </div>

    <div class="section-title">Delimiter (@Detail.Delimiters.Count)</div>
    <div style="padding-left:1.25rem;">
        @if (Detail.Delimiters.Any())
        {
            @foreach (var (d, count) in RunLengthEncode(Detail.Delimiters))
            {
                <span class="pill" style="background:#fff0f6;color:#a61e4d;display:inline-flex;align-items:center;gap:5px;">
                    '@(d == '\t' ? "\\t" : d == ' ' ? " " : d.ToString())'
                    @if (count > 1) {
                        <span style="background:rgba(0,0,0,0.12);border-radius:20px;font-size:11px;font-weight:500;padding:1px 5px;">× @count</span>
                    }
                </span>
            }
        }
        else
        {
            <span style="color:#adb5bd;font-size:12px;">none detected</span>
        }
    </div>
    
    <details id="schemas-root" @ontoggle="OnSchemasToggle">
        <summary class="section-title" style="cursor:pointer;list-style:none;display:flex;align-items:center;gap:6px;">
            <span class="arrow">&#9654;</span>
            <span>Schema (@Detail.Schemas.Count)</span>
        </summary>
        @if (Detail.Schemas.Any())
        {
            @for (var i = 0; i < Detail.Schemas.Count; i++)
            {
                var schema = Detail.Schemas[i];
                var idx = i + 1;
                <details style="margin:6px 0;padding-left:1.5rem;">
                    <summary style="font-size:11px;color:#868e96;cursor:pointer;list-style:none;display:flex;align-items:center;gap:4px;">
                        <span class="arrow">&#9654;</span>
                        <span>Schema @idx (@schema.Count columns)</span>
                    </summary>
                    <table class="detail-table" style="margin-top:6px;margin-left:1.5rem;width:calc(100% - 1.5rem);table-layout:fixed;">
                        <thead><tr><th>Position</th><th>Type</th></tr></thead>
                        <tbody>
                        @foreach (var (col, type) in schema)
                        {
                            <tr><td>@col</td><td>@type</td></tr>
                        }
                        </tbody>
                    </table>
                </details>
            }
        }
        else
        {
            <div style="margin-top:10px;color:#adb5bd;font-size:12px;">none detected</div>
        }
    </details>
    
    @if (Detail.EncodingSegments.Any())
    {
        // GroupBy keys (two places)
        var byCount = Detail.EncodingSegments
            .GroupBy(s => s.DisplayEncoding)
            .OrderByDescending(g => g.Count())
            .ToList();

        var bySize = Detail.EncodingSegments
            .GroupBy(s => s.DisplayEncoding)
            .OrderByDescending(g => g.Sum(x => x.Length))
            .ToList();

        <div class="section-title">Encoding</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;padding-left:1.25rem;">

            <div>
                <div style="font-size:11px;color:#868e96;text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px;">By segment count</div>
                <table class="detail-table">
                    <thead><tr><th>Encoding</th><th style="text-align:right;">Segments</th></tr></thead>
                    <tbody>
                    @foreach (var g in byCount)
                    {
                        <tr>
                            <td>@g.Key</td>
                            <td style="text-align:right;">@g.Count()</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <div>
                <div style="font-size:11px;color:#868e96;text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px;">By total size</div>
                <table class="detail-table">
                    <thead><tr><th>Encoding</th><th style="text-align:right;">Size</th></tr></thead>
                    <tbody>
                    @foreach (var g in bySize)
                    {
                        <tr>
                            <td>@g.Key</td>
                            <td style="text-align:right;">@Formatter.Bytes(g.Sum(x => x.Length))</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

        </div>
    }

            @if (Detail.EncodingSegments.Any())
            {
    <details>
        <summary class="section-title" style="cursor:pointer;list-style:none;display:flex;align-items:center;gap:6px;">
            <span class="arrow">&#9654;</span>
            <span>Encoding Segments (@Detail.EncodingSegments.Count)</span>
        </summary>
        <div style="margin-top:10px;padding-left:1.25rem;">
                <table class="detail-table">
                    <thead><tr><th>Start</th><th>End</th><th>Encoding</th></tr></thead>
                    <tbody>
                    @foreach (var s in Detail.EncodingSegments)
                    {
                        <tr>
                            <td>@Formatter.Number(s.Start) B</td>
                            <td>@Formatter.Number(s.EndOffset) B</td>
                            <td>@s.DisplayEncoding</td>
                        </tr>
                    }
                    </tbody>
                </table>
        </div>
    </details>
            }
    
    </div>
}
